{
  "name": "quartermaster",
  "version": "2.0.0",
  "description": "Multi-harness agent artifact manager — deploy, audit, sync, and organize skills, plugins, hooks, and MCP configs across Claude Code, Codex, Antigravity, OpenCode, and more.",
  "type": "module",
  "module": "src/cli/index.ts",
  "main": "src/cli/index.ts",
  "types": "src/core/types.ts",
  "scripts": {
    "build": "bun build --compile --outfile=dist/quartermaster --target=bun-linux-x64 ./src/cli/index.ts",
    "build:mac": "bun build --compile --target=bun-darwin-x64 ./src/cli/index.ts",
    "dev": "bun --watch src/cli/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit --project tsconfig.src.json",
    "typecheck:all": "tsc --noEmit",
    "lint": "biome lint src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "js-yaml": "4.1.0",
    "smol-toml": "1.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "1.3.14",
    "@types/js-yaml": "4.0.9",
    "typescript": "5.8.3"
  },
  "bin": {
    "qm": "./dist/quartermaster"
  },
  "files": [
    "dist/",
    "profiles/"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT"
}
