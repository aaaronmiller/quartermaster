# Quartermaster — environment configuration
# Copy to .env and fill in. Values here are the exact defaults used by
# `src/core/config/schema.ts`; set only the fields you want to override.

# ── Library & catalog ─────────────────────────────────────────
# Roots scanned for agent artifacts (space-separated; defaults to ~/.quartermaster/library)
# QUARTERMASTER_ROOTS=

# SQLite catalog DB path (default ~/.quartermaster/catalog.db)
# QUARTERMASTER_DB_PATH=

# Custom profile directory for developer-defined harness profiles (default ~/.quartermaster/profiles)
# QUARTERMASTER_PROFILE_DIR=

# ── Target harnesses ──────────────────────────────────────────
# Active harness names for deploy/all (comma-separated)
# QUARTERMASTER_HARNESSES=

# Named harness groups (JSON: {"dev": ["claude-code","codex"], "prod": ["claude-code"]})
# QUARTERMASTER_HARNESS_GROUPS=

# ── Safety ────────────────────────────────────────────────────
# Deploy gate: artifacts with safety score below this value are blocked (0..1; default 0.6).
# Higher = stricter gate.
# QUARTERMASTER_SAFETY_THRESHOLD=0.6

# ── Optional composition ──────────────────────────────────────
# Enable Noun/Verb/Adjective chain validation (default false; core deploy unaffected).
# QM_COMPOSITION_ENABLED=false

# ── Eval / model gateway (FR-103) ─────────────────────────────
# API key for the model endpoint — read from this env var at call time (never stored in config).
# The name itself must be set here; the actual key value is never committed.
QM_EVAL_API_KEY=

# Eval provider label (openai-compatible / anthropic / …)
# QM_EVAL_PROVIDER=openai-compatible

# Model endpoint base URL (leave blank to use the default OpenAI-compatible host)
# QM_EVAL_BASE_URL=

# Default model id when a task doesn't specify one
# QM_EVAL_DEFAULT_MODEL=

# Per-task model overrides (JSON: {"bulk":"gpt-4o-mini","deep":"gpt-4o"})
# QM_EVAL_MODELS=

# Multi-turn investigation turn budget (positive integer; default 8)
# QM_EVAL_TURN_BUDGET=8

# ── Optional MCP server (FR-132) ──────────────────────────────
# Off by default; uncomment to enable the JSON-RPC query server
# QM_MCP_ENABLED=true
